# Gravity Claw — Environment Variables
# Bu dosyayı .env olarak kopyalayın ve gerçek değerleri girin.
# ASLA gerçek anahtarları bu template dosyasına yazmayın!

# Telegram Bot Token — @BotFather'dan alınır
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic (Claude) API Key — console.anthropic.com'dan alınır
MODEL_API_KEY=your_anthropic_api_key_here

# Telegram User ID — sadece bu ID'ye sahip kullanıcı bota erişebilir
# Öğrenmek için Telegram'da @userinfobot'a mesaj gönderin
TELEGRAM_ALLOWLIST_USER_ID=your_telegram_user_id_here

# ─── Voice / Transcription ───

# OpenAI API Key (Whisper transcription için)
# platform.openai.com → API Keys'den alınır
# Bu değer ASLA loglara yazılmaz.
TRANSCRIPTION_API_KEY=your_openai_api_key_here

# OpenAI API Key (TTS sesli yanıt için)
# Whisper ile aynı anahtar kullanılabilir.
TTS_API_KEY=your_openai_api_key_here

# ─── Experimental & Periodic Services ───

# Daily Heartbeat Message (08:00 her gün)
HEARTBEAT_ENABLED=false

# Long-term Memory (Experimental VDB)
VECTOR_DB_API_KEY=your_vdb_api_key_here
VECTOR_DB_INDEX=your_vdb_index_name_here

# ─── MCP Tools ───

# Notion (MCP)
# https://www.notion.so/my-integrations adresinden oluşturun
NOTION_API_KEY=your_notion_api_key_here

# Google (Calendar & Drive MCP)
# Google Cloud Console -> OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# Mock modu: gerçek API çağırmadan test etmek için "true" yapın
# Geliştirme/test ortamında kullanışlıdır
MOCK_TRANSCRIPTION=false
